# Supabase connection (required at build + runtime)
# Client-side (Vite build-time injected) values:
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side (SSR) fallback values — set to the same values as above:
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# AI Assistant (NVIDIA NIM — Hermes model). Server-side only, optional.
# Get a free key at https://build.nvidia.com and paste it below.
NVIDIA_API_KEY=
NVIDIA_MODEL=nousresearch/hermes-3-llama-3.1-70b
