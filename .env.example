# Supabase connection (required at build + runtime)
# Client-side (Vite build-time injected) values:
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side (SSR) values — set to the same project URL/key as above:
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-side only, REQUIRED for reporting, voting, comments, admin panel, and
# all other server functions in src/lib/*.functions.ts (they use the service
# role client to bypass RLS). Get this from Supabase → Project Settings → API
# → "service_role" secret key. Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY=

# AI Assistant (Mistral). Server-side only, optional — without it the chat
# assistant shows a friendly "not switched on yet" message instead of erroring.
# Get a free key at https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Geocoding (LocationIQ). Server-side only, optional — without it reverse/
# forward geocoding automatically falls back to the public Nominatim API.
# Get a free key (5,000 requests/day, no credit card) at https://locationiq.com
LOCATIONIQ_API_KEY=
